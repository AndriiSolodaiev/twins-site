    .gallery-wrap 
        .gallery-swiper__wrapper
            .gallery-swiper.swiper
                .gallery-swiper-wrapper.swiper-wrapper
                    .swiper-slide(data-category="lobby")
                        //- .gallery-parallax-bg(style="background-image:url(./assets/images/gallery/1.jpg);" data-swiper-parallax="200")
