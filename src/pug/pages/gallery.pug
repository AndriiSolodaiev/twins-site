        .slider-nav-mobile  
            .slider-nav.gallery-slider-nav-prev.slider-nav-prev.swiper-button-prev
                <svg class="slider-nav-prev-svg" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7 1.00004L13 7.00001M13 7.00001L7 13M13 7.00001L1 7.00001" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            .slider-nav.gallery-slider-nav-next.slider-nav-next.swiper-button-next
                <svg class="slider-nav-next-svg" width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7 1.00004L13 7.00001M13 7.00001L7 13M13 7.00001L1 7.00001" stroke="white" stroke-linecap="round" stroke-linejoin="round"/>
